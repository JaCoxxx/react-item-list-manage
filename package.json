{
	"name": "vite-react-template",
	"description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
	"cloudflare": {
		"label": "Vite React Template",
		"products": [
			"Workers"
		],
		"categories": [],
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/532a5378-9717-4964-385b-5fafd2160200/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/ec7f4be5-d1d6-4e94-0851-126341745400/preview",
		"publish": true
	},
	"dependencies": {
		"@ant-design/icons": "^6.1.1",
		"antd": "^6.3.5",
		"dayjs": "^1.11.20",
		"hono": "4.11.1",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"react-router-dom": "^7.14.1"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "1.15.3",
		"@eslint/js": "9.39.1",
		"@types/node": "24.10.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "5.1.1",
		"eslint": "9.39.2",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.4.24",
		"globals": "16.5.0",
		"typescript": "5.8.3",
		"typescript-eslint": "8.48.0",
		"vite": "^6.0.0",
		"wrangler": "4.56.0"
	},
	"private": true,
	"scripts": {
		"build": "tsc -b && node -r ./scripts/node-web-globals.cjs ./node_modules/vite/bin/vite.js build",
		"cf-typegen": "wrangler types",
		"check": "tsc && node -r ./scripts/node-web-globals.cjs ./node_modules/vite/bin/vite.js build && wrangler deploy --dry-run",
		"d1:init:local": "npm_config_loglevel=silent npx -y node@20 ./node_modules/wrangler/bin/wrangler.js d1 execute item-list-db --file=./db/schema.sql && npm_config_loglevel=silent npx -y node@20 ./node_modules/wrangler/bin/wrangler.js d1 execute item-list-db --file=./db/seed.sql",
		"d1:init:remote": "npm_config_loglevel=silent npx -y node@20 ./node_modules/wrangler/bin/wrangler.js d1 execute item-list-db --remote --file=./db/schema.sql && npm_config_loglevel=silent npx -y node@20 ./node_modules/wrangler/bin/wrangler.js d1 execute item-list-db --remote --file=./db/seed.sql",
		"deploy": "wrangler deploy",
		"dev": "node ./scripts/ensure-local-d1.cjs && node -r ./scripts/node-web-globals.cjs ./node_modules/vite/bin/vite.js",
		"dev:remote-db": "CLOUDFLARE_ENV=remote_db CF_REMOTE_BINDINGS=1 npm_config_loglevel=silent npx -y node@20 -r ./scripts/node-web-globals.cjs ./node_modules/vite/bin/vite.js",
		"lint": "eslint .",
		"preview": "npm run build && node -r ./scripts/node-web-globals.cjs ./node_modules/vite/bin/vite.js preview"
	},
	"type": "module"
}
